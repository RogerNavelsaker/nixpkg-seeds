{
  "name": "@os-eco/seeds-cli",
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "show-manifest": "bun --eval \"console.log(await Bun.file('nix/package-manifest.json').text())\"",
    "sync:source": "bun run sync:github-source",
    "sync:manifest": "bun run sync:github-source",
    "sync:github-source": "bun run scripts/sync-from-github.ts",
    "sync:npm-source": "bun run scripts/sync-from-npm.ts",
    "postinstall": "bun x bun2nix -o bun.nix"
  },
  "dependencies": {
    "ajv": "^8",
    "chalk": "^5.6.2",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "@types/bun": "^1.3.10",
    "knip": "^6",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "typescript": "^5.9.0",
    "bun2nix": "2.0.8"
  },
  "version": "0.5.10",
  "description": "Git-native issue tracker for AI agent workflows",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jayminwest/seeds.git"
  },
  "homepage": "https://github.com/jayminwest/seeds/tree/main",
  "bugs": {
    "url": "https://github.com/jayminwest/seeds/issues"
  },
  "keywords": [
    "issue-tracking",
    "git",
    "ai",
    "agents",
    "cli",
    "developer-tools"
  ],
  "bin": {
    "sd": "./src/index.ts"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}
